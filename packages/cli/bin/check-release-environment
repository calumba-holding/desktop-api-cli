#!/usr/bin/env bash
set -euo pipefail

errors=()

for path in package.json bun.lock scripts/build-homebrew-archive.ts scripts/publish-homebrew-formula.ts .github/workflows/publish-release.yml; do
  if [[ ! -f "${path}" ]]; then
    errors+=("Missing required release file: ${path}")
  fi
done

for command in bun git gh tar; do
  if ! command -v "${command}" >/dev/null 2>&1; then
    errors+=("Missing required release command: ${command}")
  fi
done

lenErrors=${#errors[@]}

if [[ lenErrors -gt 0 ]]; then
  echo -e "Found the following errors in the release environment:\n"

  for error in "${errors[@]}"; do
    echo -e "- $error\n"
  done

  exit 1
fi

echo "The environment is ready to push releases!"
