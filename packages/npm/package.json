{
  "name": "beeper-cli",
  "version": "0.6.1",
  "description": "Beeper CLI binary launcher",
  "license": "MIT",
  "type": "module",
  "bin": {
    "beeper": "./bin/beeper.js"
  },
  "files": [
    "bin",
    "binaries.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "clean": "rm -rf bin binaries.json README.md LICENSE",
    "test": "bun run build",
    "typecheck": "bun build scripts/build.ts --target=bun --outdir=/private/tmp/beeper-cli-npm-check --entry-naming='[name].js'"
  }
}
